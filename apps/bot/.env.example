# Gemini API Keys - Hỗ trợ KHÔNG GIỚI HẠN số lượng keys
# Khi gặp lỗi 429 (rate limit), hệ thống sẽ tự động chuyển sang key tiếp theo và gọi ngay
# Khi gặp lỗi 503 (overload), hệ thống sẽ retry với delay, không đổi key
#
# Cách 1: Một dòng (ngang) - comma-separated
# GEMINI_API_KEY=key1,key2,key3,...
#
# Cách 2: Nhiều dòng (dọc) - dễ quản lý hơn, KHÔNG GIỚI HẠN số lượng
# GEMINI_API_KEY_1=key1
# GEMINI_API_KEY_2=key2
# GEMINI_API_KEY_3=key3
# ... có thể thêm bao nhiêu key tùy ý (GEMINI_API_KEY_100, GEMINI_API_KEY_999, ...)

GEMINI_API_KEY=your_gemini_api_key
# Hoặc dùng format dọc (không giới hạn):
# GEMINI_API_KEY_1=your_gemini_api_key_1
# GEMINI_API_KEY_2=your_gemini_api_key_2
# GEMINI_API_KEY_3=your_gemini_api_key_3
# ... thêm bao nhiêu key tùy ý

# API Key - Bảo vệ tất cả API endpoints
# Dùng chung cho cả bot và web dashboard
# Nếu không set, API sẽ public (chỉ dùng cho dev)
# Generate: openssl rand -hex 32
API_KEY=your_random_api_key

# Log Receiver - Zalo User ID để nhận log files (production only)
# Khi đủ 1000 dòng log, bot sẽ gửi file log qua Zalo cho user này
LOG_RECEIVER_ID=your_zalo_user_id

# ============================================
# ZALO CREDENTIALS (cho Cloud Deployment)
# ============================================
# Khi deploy lên Railway/Render, không có file credentials.json
# Cần lưu credentials vào env var
#
# Cách lấy: Chạy bot local lần đầu, quét QR, bot sẽ in ra base64 string
# Copy string đó vào đây
#
# ZALO_CREDENTIALS_BASE64=eyJ1aWQiOiIxMjM0NTY3ODkwIi...
#
# Hoặc dùng JSON string (không khuyến khích vì dài):
# ZALO_CREDENTIALS_JSON={"uid":"1234567890",...}
