{
  "name": "@zia/bot",
  "version": "1.0.0",
  "description": "Zia - Zalo AI Bot using zca-js and Google Gemini",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/app/main.ts",
    "dev": "bun --watch src/app/main.ts",
    "db:studio": "bun drizzle-kit studio",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun drizzle-kit migrate",
    "format": "bunx biome format --write ./src",
    "lint": "bunx biome check ./src",
    "tsc": "npx tsc --noEmit",
    "lint:fix": "bunx biome check --write ./src",
    "test": "bun test",
    "test:integration": "bun test tests/integration --timeout 60000",
    "test:integration:watch": "bun test tests/integration --watch --timeout 60000",
    "test:system": "bun test tests/integration/system --timeout 60000",
    "test:ai": "bun test tests/integration/ai --timeout 60000",
    "test:database": "bun test tests/integration/database --timeout 60000",
    "test:files": "bun test tests/integration/files --timeout 60000",
    "test:utils": "bun test tests/integration/utils --timeout 60000",
    "test:core": "bun test tests/integration/core --timeout 60000",
    "test:gateway": "bun test tests/integration/gateway --timeout 60000",
    "test:e2e": "bun test tests/e2e --timeout 120000"
  },
  "keywords": ["zalo", "bot", "gemini", "ai"],
  "license": "MIT",
  "dependencies": {
    "@e2b/code-interpreter": "^2.6.1",
    "@google/genai": "^2.11.0",
    "cfb": "^1.2.2",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dayjs": "^1.11.21",
    "docx": "^9.7.1",
    "docx-parser": "^0.2.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.29",
    "jsonrepair": "^3.15.0",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "ky": "^2.0.2",
    "msedge-tts": "^2.0.7",
    "mammoth": "^1.12.0",
    "officeparser": "^7.2.3",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "pptxgenjs": "^4.0.1",
    "rxjs": "^7.8.2",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "svg-to-pdfkit": "^0.1.8",
    "word-extractor": "^1.0.4",
    "zca-js": "^2.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/katex": "^0.16.8",
    "@types/pdfkit": "^0.17.6",
    "better-sqlite3": "^12.11.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  }
}
